{
  "name": "ts-fastify-vue-app",
  "version": "1.0.0",
  "description": "A full-stack TypeScript app using Fastify, Prisma, and Vue",
  "main": "index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "client": "vite --config client/vite.config.ts",
    "client:build": "vite build --config client/vite.config.ts",
    "client:preview": "vite preview --config client/vite.config.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev"
  },
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.5.0",
    "fastify": "^4.27.2",
    "fastify-cors": "^8.4.0",
    "fastify-plugin": "^4.5.0",
    "fastify-jwt": "^5.0.1",
    "fastify-static": "^6.9.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.8.0",
    "@vitejs/plugin-vue": "^5.0.4",
    "prisma": "^5.5.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3",
    "vite": "^5.2.0",
    "vue": "^3.4.18",
    "vue-router": "^4.3.3",
    "pinia": "^2.1.7"
  }
}
